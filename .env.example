# =============================================================================
# Starlink Enterprise MCP Server — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Starlink API endpoints (defaults are correct for production) ---
# Base URL of the Starlink Enterprise API. Paths are /public/v2/...
STARLINK_API_URL=https://web-api.starlink.com
# OIDC token endpoint for the client_credentials grant.
STARLINK_TOKEN_URL=https://www.starlink.com/api/auth/connect/token

# --- stdio mode: operator service account (V2 Service Account) ---
# Create at https://www.starlink.com/account/settings → "API V2 Service Accounts".
# In stdio mode these credentials are exchanged for a bearer via client_credentials.
STARLINK_CLIENT_ID=
STARLINK_CLIENT_SECRET=

# --- stdio mode alternative: a pre-minted bearer token ---
# If you already have a Starlink access token, set it directly and skip the grant.
# STARLINK_ACCESS_TOKEN=

# --- HTTP transport (hosted) — auth mode ---
# MCP_AUTH_MODE selects how the server gets each connection's Starlink creds:
#   • passthrough → the MCP client (Claude/ChatGPT) is configured with the
#                   Starlink Service Account as its OAuth client_id + secret;
#                   the server validates them against Starlink at /token and
#                   forwards them. No login page, no server-side creds.
#   • (unset)     → if STARLINK_CLIENT_ID/SECRET are set below, single-account
#                   mode (login skipped, shared account); otherwise multi-tenant
#                   mode (each user pastes their creds on the login page).
# MCP_AUTH_MODE=passthrough
# MCP_TRANSPORT=http          # http (default in Docker) or stdio
# MCP_PORT=3000               # Port to listen on (default: 3000)
# MCP_HOST=0.0.0.0            # Bind address (default: 0.0.0.0)

# Public base URL of this server — used for OAuth metadata discovery and
# redirect URIs. Must match what MCP clients use to connect.
MCP_BASE_URL=https://mcp.yourdomain.com

# Signs login-state cookies. 32+ chars, MUST be stable across instances/restarts.
MCP_SESSION_SECRET=

# --- Persistence ---
# firestore (recommended on Cloud Run) or file (default, ~/.starlink-mcp).
# MCP_PERSISTENCE=firestore
# GOOGLE_CLOUD_PROJECT=       # Firestore project ID (auto-set on Cloud Run)

# --- Optional: CORS ---
# MCP_CORS_ORIGIN=*           # Allowed origins (default: * — restrict in production)

# --- Optional: tool gating ---
# MCP_DISABLED_TOOLS=delete_*,reboot_*    # comma-separated globs to hide tools
# MCP_DISABLED_ACTIONS=                   # comma-separated action arg values to block
# MCP_DISABLE_DESTRUCTIVE=true            # hide every tool that mutates irreversibly

# --- Optional: branding ---
# MCP_LOGIN_HEADER=Starlink MCP — Sign In
# MCP_ICON_URL=https://example.com/icon.png
# MCP_LOGIN_LOGO_URL=https://example.com/logo.png

# --- Optional: logging ---
# LOG_LEVEL=info              # debug, info, warn, error (default: info)
# DEBUG=false                 # Enable debug logging (default: false)
