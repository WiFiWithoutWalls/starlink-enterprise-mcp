{
  "name": "starlink-enterprise-mcp",
  "version": "1.0.0",
  "description": "Starlink Enterprise API MCP Server",
  "main": "build/index.js",
  "bin": {
    "starlink-enterprise-mcp": "build/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node build/index.js",
    "watch": "tsx watch src/index.ts",
    "clean": "rimraf build",
    "generate": "tsx scripts/generate-tools.ts",
    "prebuild": "npm run clean && npm run generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "starlink",
    "spacex",
    "satellite",
    "enterprise",
    "api",
    "integration"
  ],
  "author": "WiFi Without Walls",
  "license": "MIT",
  "dependencies": {
    "@google-cloud/firestore": "^8.6.0",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "axios": "^1.6.0",
    "express": "^5.0.0",
    "express-rate-limit": "^7.4.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.2.0",
    "ajv": "^8.17.1",
    "rimraf": "^5.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "build/**/*",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wifiwithoutwalls/starlink-enterprise-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/wifiwithoutwalls/starlink-enterprise-mcp/issues"
  },
  "homepage": "https://github.com/wifiwithoutwalls/starlink-enterprise-mcp#readme"
}
